{
  "extends": "next/core-web-vitals",
  "settings": {
    "next": {
      "rootDir": "."
    }
  },
  "rules": {
    "@next/next/no-html-link-for-pages": "off"
  },
  "overrides": [
    {
      "files": ["**/*.tsx"],
      "rules": {
        "max-lines": ["warn", { "max": 800, "skipBlankLines": true, "skipComments": true }]
      }
    }
  ]
}
