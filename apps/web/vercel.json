{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && npm ci",
  "buildCommand": "cd ../.. && npm run build",
  "crons": [
    {
      "path": "/api/integrations/garmin/pull/cron",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/integrations/whoop/pull/cron",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/onboarding/email/cron?send=true",
      "schedule": "0 * * * *"
    }
  ]
}
